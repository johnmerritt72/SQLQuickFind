<Window x:Class="SQLQuickFind.UI.PickDatabaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multiple matches found"
        Width="420" Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="HeaderText" Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap" />
        <ListBox x:Name="DbList" Grid.Row="1"
                 DisplayMemberPath="QualifiedDisplay"
                 MouseDoubleClick="DbList_MouseDoubleClick" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK" Width="80" IsDefault="True" Click="OkButton_Click" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
